generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum ColumnTitle {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum Prioriy {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

model User {
  id       String @id @default(uuid())
  fullName String
  email    String @unique()
  phoneNo  String
  password String

  profilePhoto String?
  refreshToken String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt()
  deletedAt    DateTime?

  boards   Boards[]
  tasks    Tasks[]
  taskActs Task_Act[]
}

model Boards {
  id        String    @id @default(uuid())
  boardName String
  userId    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt()
  deletedAt DateTime?

  createdBy User      @relation(fields: [userId], references: [id])
  columns   Columns[]

  @@index([userId, deletedAt])
}

model Columns {
  id      String      @id @default(uuid())
  title   ColumnTitle
  boardId String
  order   Int

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt()
  deletedAt DateTime?

  board Boards  @relation(fields: [boardId], references: [id])
  tasks Tasks[]

  @@unique([title, boardId, order])
  @@index([boardId, deletedAt, order])
}

model Tasks {
  id String @id @default(uuid())

  title       String
  description String
  assigneeId  String
  labels      String
  dueDate     DateTime
  priority    Prioriy
  position    Int

  columnId String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt()
  deletedAt DateTime?

  column     Columns     @relation(fields: [columnId], references: [id])
  user       User        @relation(fields: [assigneeId], references: [id])
  taskLabels TaskLabel[]

  @@index([assigneeId])
  @@index([columnId, deletedAt, position])
}

model TaskLabel {
  id    String @id @default(uuid())
  name  String
  color String

  taskId String
  task   Tasks  @relation(fields: [taskId], references: [id])

  @@index([taskId])
}

model Task_Act {
  id    String @id @default(uuid())
  title String

  user   User   @relation(fields: [userId], references: [id])
  userId String

  @@index([userId])
}
